/* ================================
   Character Preview - DarkHandDrawnFantasy Theme
   ================================ */

/* Character Preview Background */
.character-preview--theme-art {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Frames/SettingsPanel');
}

/* Item Slot Background */
.item-slot--theme-art {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Buttons/ButtonBackground');
}

/* Character Preview Container Background */
.char-preview-container--theme-art {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Buttons/ButtonBackground');
}

/* Character Image */
.char-preview__image--theme-art {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Characters/Warrior');
}

/* Stats Info Container Background */
.stats-info-container--theme-art {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Buttons/ButtonBackground');
}

/* Item Slot Icon Specific Styles */
.item-slot__icon--dragonfang-claymore {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Items/Dragonfang_Claymore');
}

.item-slot__icon--alchemist-goggles {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Items/Alchemist\'s_Goggles');
}

.item-slot__icon--siren-tear-amulet {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Items/Siren\'s_Tear_Amulet');
}

.item-slot__icon--dragon-scale-belt {
    background-image: resource('LiberateUI/DarkHandDrawnFantasy/Items/Dragon_Scale_Belt');
}
