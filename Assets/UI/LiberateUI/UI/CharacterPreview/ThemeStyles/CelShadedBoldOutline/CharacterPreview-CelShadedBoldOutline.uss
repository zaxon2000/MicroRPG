/* ================================
   Character Preview - CelShadedBoldOutline Theme
   ================================ */

/* Character Preview Background */
.character-preview--theme-art {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Frames/SettingsPanel');
}

/* Item Slot Background */
.item-slot--theme-art {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Frames/Frame_0');
}

/* Character Preview Container Background */
.char-preview-container--theme-art {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Frames/Frame_1');
}

/* Character Image */
.char-preview__image--theme-art {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Characters/Wizard');
}

/* Stats Info Container Background */
.stats-info-container--theme-art {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Frames/Frame_1');
}

/* Item Slot Icon Specific Styles */
.item-slot__icon--dragonfang-claymore {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Items/Citrus_Bomb');
}

.item-slot__icon--alchemist-goggles {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Items/Azure_Wave_Staff');
}

.item-slot__icon--siren-tear-amulet {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Items/Flame_Shard_Dagger');
}

.item-slot__icon--dragon-scale-belt {
    background-image: resource('LiberateUI/CelShadedBoldOutline/Items/Copper_Shell_Shield');
}
