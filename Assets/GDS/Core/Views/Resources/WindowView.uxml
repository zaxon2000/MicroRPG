<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Window" class="window">
        <ui:Label tabindex="-1" text="Window Title" parse-escape-sequences="true" display-tooltip-when-elided="true" name="TitleLabel" class="window-title" />
        <ui:VisualElement name="Container" class="window-container" />
        <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="CloseButton" class="close-button" />
    </ui:VisualElement>
</ui:UXML>
